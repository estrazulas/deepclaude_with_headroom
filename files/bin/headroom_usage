#!/usr/bin/env bash
# Helper script for /headroom_usage command
# Display Headroom proxy savings statistics

# Load environment (HEADROOM_API_KEY required for /stats endpoint)
ENV_FILE="$HOME/.config/headroom/env"
if [ -f "$ENV_FILE" ]; then
  source "$ENV_FILE"
fi

STATS=$(curl -sf -H "Authorization: Bearer ${HEADROOM_API_KEY}" http://localhost:8787/stats 2>/dev/null)

if [ -z "$STATS" ]; then
  echo "❌ Headroom proxy is not responding at localhost:8787"
  echo "   Check with: systemctl --user status headroom.service"
  echo "   Or the HEADROOM_API_KEY in ~/.config/headroom/env is missing/wrong"
  exit 1
fi

# Flags opcionais
if [ "$1" = "-v" ] || [ "$1" = "--verbose" ]; then
  echo "$STATS" | python3 -m json.tool 2>/dev/null || echo "$STATS"
  exit 0
fi

if [ "$1" = "-j" ] || [ "$1" = "--json" ]; then
  echo "$STATS"
  exit 0
fi

if [ "$1" = "-p" ] || [ "$1" = "--prometheus" ]; then
  curl -sf http://localhost:8787/metrics
  exit 0
fi

# Formatted dashboard
echo "╔══════════════════════════════════════╗"
echo "║   📊 HEADROOM USAGE                  ║"
echo "╚══════════════════════════════════════╝"
echo ""

# Current session
echo "━━━ CURRENT SESSION ━━━"
echo "$STATS" | jq -r '
  .display_session as $s |
  "  📥 Requests:        \($s.requests) reqs",
  "  📝 Input tokens:    \($s.total_input_tokens | tostring) tok",
  "  💰 Tokens saved:    \($s.tokens_saved | tostring) tok  (\($s.savings_percent)% reduction)",
  "  ⏱  Duration:         \($s.started_at[:16] | sub("T"; " ")) — present"
'

echo ""
echo "━━━ LIFETIME — TOTAL ━━━"
echo "$STATS" | jq -r '
  .persistent_savings.lifetime as $l |
  "  📥 Requests:        \($l.requests) reqs",
  "  📝 Input tokens:    \($l.total_input_tokens | tostring) tok",
  "  💰 Tokens saved:    \($l.tokens_saved | tostring) tok",
  "  📉 Total reduction:  \($l.savings_percent)%"
'

echo ""
echo "━━━ COMPRESSION ━━━"
echo "$STATS" | jq -r '
  .summary.compression as $c |
  "  🔧 Reqs compressed:  \($c.requests_compressed) of \(.summary.api_requests) reqs",
  "  📉 Avg compression:   \($c.avg_compression_pct)%",
  "  🏆 Best case:         \($c.best_compression_pct)%  (\($c.best_detail))",
  "  🔢 Tokens removed:    \($c.total_tokens_removed | tostring) tok"
'

echo ""
echo "━━━ CACHE ━━━"
echo "$STATS" | jq -r '
  .requests as $r |
  .prefix_cache.totals as $pc |
  "  💾 Cache hit rate:   \($r.cached / $r.total * 100 | floor)%  (\($r.cached)/\($r.total) reqs)",
  "  📖 Cache read:       \($pc.cache_read_tokens | tostring) tok",
  "  ❌ Cache busts:       \($pc.bust_count) (0 tok lost)"
'

echo ""
echo "━━━ PERFORMANCE ━━━"
echo "$STATS" | jq -r '
  .latency as $l |
  .overhead as $o |
  "  ⏳ Avg latency:       \($l.average_ms | floor)ms",
  "  ⚡ Headroom Overhead: \($o.average_ms | floor)ms (min \($o.min_ms)ms / max \($o.max_ms)ms)",
  "  🚀 Avg TTFB:          \(.ttfb.average_ms | floor)ms"
'

echo ""
echo "━━━ MODELS ━━━"
echo "$STATS" | jq -r '
  .requests.by_model | to_entries | .[] |
  "  🤖 \(.key): \(.value) reqs"
'

echo ""
echo "━━━ RECENT (last requests) ━━━"
echo "$STATS" | jq -r '
  .recent_requests[-5:] | reverse | .[] |
  "  [\(.timestamp[11:19])] \(.model) | \(.input_tokens_original) → \(.input_tokens_optimized) tok | -\(.tokens_saved) tok (\(.savings_percent | floor)%) | cache=\(.cache_hit)"
' 2>/dev/null || echo "  (no recent data)"

echo ""
echo "━━━"
echo "$STATS" | jq -r '
  if .cost.savings_usd != 0 then
    "💰 Savings in USD: $" + (.cost.savings_usd | tostring)
  else
    "💡 Savings in USD unavailable (prices not configured on proxy)"
  end
'
echo ""
echo "➡️  Use /headroom_usage -v  for full JSON"
echo "   Use /headroom_usage -p  for Prometheus metrics"
