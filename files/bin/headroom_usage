#!/usr/bin/env bash
# Helper script for /headroom_economy command
# Mostra estatísticas de economia do Headroom proxy

STATS=$(curl -sf http://localhost:8787/stats 2>/dev/null)

if [ -z "$STATS" ]; then
  echo "❌ Headroom proxy não está respondendo em localhost:8787"
  echo "   Verifique com: systemctl --user status headroom.service"
  exit 1
fi

# Flags opcionais
if [ "$1" = "-v" ] || [ "$1" = "--verbose" ]; then
  echo "$STATS" | python3 -m json.tool 2>/dev/null || echo "$STATS"
  exit 0
fi

if [ "$1" = "-j" ] || [ "$1" = "--json" ]; then
  echo "$STATS"
  exit 0
fi

if [ "$1" = "-p" ] || [ "$1" = "--prometheus" ]; then
  curl -sf http://localhost:8787/metrics
  exit 0
fi

# Dashboard formatado
echo "╔══════════════════════════════════════╗"
echo "║   📊 HEADROOM ECONOMY               ║"
echo "╚══════════════════════════════════════╝"
echo ""

# Sessão atual
echo "━━━ SESSÃO ATUAL ━━━"
echo "$STATS" | jq -r '
  .display_session as $s |
  "  📥 Requests:        \($s.requests) reqs",
  "  📝 Input tokens:    \($s.total_input_tokens | tostring) tok",
  "  💰 Tokens salvos:   \($s.tokens_saved | tostring) tok  (\($s.savings_percent)% de redução)",
  "  ⏱  Duração:         \($s.started_at[:16] | sub("T"; " ")) — presente"
'

echo ""
echo "━━━ LIFETIME — DESDE O INÍCIO ━━━"
echo "$STATS" | jq -r '
  .persistent_savings.lifetime as $l |
  "  📥 Requests:        \($l.requests) reqs",
  "  📝 Input tokens:    \($l.total_input_tokens | tostring) tok",
  "  💰 Tokens salvos:   \($l.tokens_saved | tostring) tok",
  "  📉 Redução total:   \($l.savings_percent)%"
'

echo ""
echo "━━━ COMPRESSÃO ━━━"
echo "$STATS" | jq -r '
  .summary.compression as $c |
  "  🔧 Reqs comprimidas: \($c.requests_compressed) de \(.summary.api_requests) reqs",
  "  📉 Média compressão: \($c.avg_compression_pct)%",
  "  🏆 Melhor caso:      \($c.best_compression_pct)%  (\($c.best_detail))",
  "  🔢 Tokens removidos: \($c.total_tokens_removed | tostring) tok"
'

echo ""
echo "━━━ CACHE ━━━"
echo "$STATS" | jq -r '
  .requests as $r |
  .prefix_cache.totals as $pc |
  "  💾 Cache hit rate:   \($r.cached / $r.total * 100 | floor)%  (\($r.cached)/\($r.total) reqs)",
  "  📖 Cache read:       \($pc.cache_read_tokens | tostring) tok",
  "  ❌ Cache busts:      \($pc.bust_count) (0 tok perdidos)"
'

echo ""
echo "━━━ PERFORMANCE ━━━"
echo "$STATS" | jq -r '
  .latency as $l |
  .overhead as $o |
  "  ⏳ Latência média:   \($l.average_ms | floor)ms",
  "  ⚡ Overhead Headroom: \($o.average_ms | floor)ms (mín \($o.min_ms)ms / máx \($o.max_ms)ms)",
  "  🚀 TTFB médio:       \(.ttfb.average_ms | floor)ms"
'

echo ""
echo "━━━ MODELOS ━━━"
echo "$STATS" | jq -r '
  .requests.by_model | to_entries | .[] |
  "  🤖 \(.key): \(.value) reqs"
'

echo ""
echo "━━━ RECENTES (últimas requisições) ━━━"
echo "$STATS" | jq -r '
  .recent_requests[-5:] | reverse | .[] |
  "  [\(.timestamp[11:19])] \(.model) | \(.input_tokens_original) → \(.input_tokens_optimized) tok | -\(.tokens_saved) tok (\(.savings_percent | floor)%) | cache=\(.cache_hit)"
' 2>/dev/null || echo "  (sem dados recentes)"

echo ""
echo "━━━"
echo "$STATS" | jq -r '
  if .cost.savings_usd != 0 then
    "💰 Economia em USD: $" + (.cost.savings_usd | tostring)
  else
    "💡 Economia em USD indisponível (preços não configurados no proxy)"
  end
'
echo ""
echo "➡️  Use /headroom_economy -v  para JSON completo"
echo "   Use /headroom_economy -p  para métricas Prometheus"
